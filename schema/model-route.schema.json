{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model-registry/model-route.schema.json",
  "title": "Model Route",
  "type": "object",
  "required": ["id", "modelId", "providerId", "routeType", "label", "status", "recordStatus"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "modelId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "providerId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "routeType": { "type": "string", "enum": ["direct", "proxy", "aggregator", "internal"] },
    "label": { "type": "string", "minLength": 1 },
    "baseUrl": { "type": "string", "format": "uri" },
    "authMethod": { "type": "string", "enum": ["api-key", "oauth", "service-account", "none", "custom"] },
    "requiredSecrets": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "supportsStreaming": { "type": "boolean" },
    "supportsTools": { "type": "boolean" },
    "supportsStructuredOutput": { "type": "boolean" },
    "supportsReasoningMode": { "type": "boolean" },
    "status": { "type": "string", "enum": ["active", "preview", "deprecated", "disabled"] },
    "recordStatus": { "type": "string", "enum": ["draft", "reviewed", "verified", "stale", "deprecated"] },
    "sourceUrl": { "type": "string", "format": "uri" },
    "lastVerifiedAt": { "type": "string", "format": "date" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
